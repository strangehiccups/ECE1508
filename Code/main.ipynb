    "# Trying to test inference\n",
    "from DataLoader import tokenizer\n",
    "\n",
    "model.eval()\n",
    "\n",
    "# Grab one batch from the test set and take the first sample\n",
    "sample_batch = next(iter(test_loader))\n",
    "spec   = sample_batch['padded_spectrograms'][[0]].to(device)   # (1, C, n_mels, T)\n",
    "length = sample_batch['input_lengths'][[0]]                    # (1,)\n",
    "\n",
    "# Ground-truth text\n",
    "gt_token_ids = sample_batch['packed_transcripts'][:sample_batch['target_lengths'][0]].tolist()\n",
    "ground_truth = tokenizer.decode(gt_token_ids)\n",
    "\n",
    "with torch.no_grad():\n",
    "    probs, out_lens = model(spec, length)          # probs: (1, T', vocab)\n",
    "\n",
    "# Greedy CTC decode: argmax at each timestep, collapse repeats, remove blanks\n",
    "blank_id = tokenizer.pad_token_id\n",
    "pred_ids = probs[0].argmax(dim=-1).tolist()\n",
    "\n",
    "collapsed = []\n",
    "prev = None\n",
    "for idx in pred_ids:\n",
    "    if idx != prev:\n",
    "        if idx != blank_id:\n",
    "            collapsed.append(idx)\n",
    "        prev = idx\n",
    "\n",
    "prediction = tokenizer.decode(collapsed)\n",
    "\n",
    "print(f\"Ground truth : {ground_truth}\")\n",
    "print(f\"Prediction   : {prediction}\")"
   ]
